# ──────────────────────────────────────────────────────────────────────────
# Amazon Blink runs FULLY in DEMO MODE with no key (pre-scripted responses),
# so a hackathon booth never depends on Wi-Fi. Set a provider below to make
# the "Bedrock" (Claude) features genuinely live.
# ──────────────────────────────────────────────────────────────────────────

# Which model backend to use: demo | anthropic | bedrock
#   demo      → no model call (default when no key is set)
#   anthropic → Anthropic API directly — fastest to test
#   bedrock   → real Amazon Bedrock — what you submit for the Amazon hackathon
PROVIDER=anthropic

# ── Anthropic direct ────────────────────────────────────────
ANTHROPIC_API_KEY=
# Optional model override. Defaults to claude-sonnet-4-6 (fast + multimodal).
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Amazon Bedrock (for the actual submission) ──────────────
# 1) npm i @aws-sdk/client-bedrock-runtime
# 2) Have AWS credentials in the environment (env vars / `aws configure` / IAM role)
# 3) Enable model access for this model in this region in the Bedrock console
# No code change needed — the provider switches on PROVIDER=bedrock.
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
